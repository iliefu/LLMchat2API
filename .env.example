# .env.example

# Example environment variables
API_KEY=your_api_key_here
DB_CONNECTION_STRING=your_database_connection_string_here
LOG_LEVEL=info

# OpenAI ChatGPT Web Token
CHATRAPPER_TOKEN=your_openai_token_here

# Qwen Chat Token
QWEN_TOKEN=your_qwen_token_here

# LLM Provider: "openai" or "qwen"
LLM_PROVIDER=openai
